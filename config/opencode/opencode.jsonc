{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "/Users/k/.config/opencode/*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "edit": {
      "*": "ask",
      "agents/**/*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": {
      "cat *": "allow",
      "find *": "allow",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "gh issue list *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "ls *": "allow",
      "pwd *": "allow",
      "rg *": "allow",
      "tail *": "allow",
      "uv add *": "allow",
      "uv sync *": "allow",
      "wc *": "allow",
      "yq *": "allow",
    },
    "task": "allow",
    "skill": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "context7_*": "allow",
    "perplexity_*": "allow"
  },

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "ctx7sk-3687b536-bffd-472b-8d7a-247eba6e0d19"
      }
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=2f073293-1321-491a-9c60-54801a803510",
      "enabled": true
    },
    "pdf-reader-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@shuji-bonji/pdf-reader-mcp"],
      "enabled": true
    }
  },

  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],

  "experimental": {
    "mcp_timeout": 600000
  }
}
